{
  "version": "1.0.0",
  "agents": {
    "claude": {
      "id": "claude-agent",
      "model": "claude-3-5-sonnet-20241022",
      "provider": "anthropic",
      "specializations": [
        "complex-reasoning",
        "architecture-design",
        "code-review",
        "system-design",
        "debugging"
      ],
      "capabilities": {
        "maxTokens": 200000,
        "supportedLanguages": [
          "typescript",
          "javascript",
          "python",
          "sql"
        ],
        "tools": [
          "code-analysis",
          "file-operations",
          "reasoning"
        ]
      },
      "priority": 1,
      "enabled": true
    },
    "gpt": {
      "id": "gpt-agent",
      "model": "gpt-4-turbo",
      "provider": "openai",
      "specializations": [
        "code-generation",
        "refactoring",
        "documentation",
        "api-design",
        "frontend-development"
      ],
      "capabilities": {
        "maxTokens": 128000,
        "supportedLanguages": [
          "typescript",
          "javascript",
          "react",
          "html",
          "css"
        ],
        "tools": [
          "code-generation",
          "completion",
          "transformation"
        ]
      },
      "priority": 2,
      "enabled": true
    },
    "gemini": {
      "id": "gemini-agent",
      "model": "gemini-1.5-pro",
      "provider": "google",
      "specializations": [
        "data-analysis",
        "testing",
        "optimization",
        "performance-analysis",
        "batch-processing"
      ],
      "capabilities": {
        "maxTokens": 1000000,
        "supportedLanguages": [
          "typescript",
          "javascript",
          "python",
          "sql"
        ],
        "tools": [
          "analysis",
          "testing",
          "batch-operations"
        ]
      },
      "priority": 3,
      "enabled": true
    }
  },
  "routing": {
    "strategy": "capability-based",
    "fallback": "claude",
    "collaborative": true,
    "learningEnabled": true
  },
  "skillLearning": {
    "enabled": true,
    "minSuccessRate": 0.8,
    "skillExtractionThreshold": 3,
    "autoGenerateSkills": true,
    "skillsDirectory": "./skills"
  },
  "memory": {
    "enabled": true,
    "maxHistorySize": 1000,
    "retentionDays": 90,
    "trackPerformance": true
  }
}